# Analytics — Plausible (optional). Leave VITE_PLAUSIBLE_DOMAIN empty in
# development; the wrapper becomes a no-op so no requests fire.
#
# For production set the domain you registered in Plausible.
# The script URL defaults to the hosted plausible.io endpoint; override
# VITE_PLAUSIBLE_SCRIPT only if you self-host.
VITE_PLAUSIBLE_DOMAIN=
VITE_PLAUSIBLE_SCRIPT=
