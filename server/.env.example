DATABASE_URL=postgresql://user:password@localhost:5432/profai?schema=public
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRATION=7d
PORT=5000
CORS_ORIGIN=http://localhost:3000
UPLOAD_MAX_SIZE=10485760

# Gemini API (Google AI Studio: https://aistudio.google.com/app/apikey)
# Runs on the AI Studio *free tier* by default; leave GEMINI_FREE_TIER=true
# unless you have upgraded to paid (Google Cloud) billing. The flag only
# affects how AICallLog rows are tagged for cost reporting.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FREE_TIER=true

# Background jobs (Phase 5+). BullMQ + Redis power the spaced-repetition
# scheduler and study-group maintenance. Leave RUN_JOBS unset on web-only
# processes (the worker tier should set it to 1). Tests use
# RUN_INLINE_QUEUE=1 to execute handlers synchronously without Redis.
REDIS_URL=redis://localhost:6379
# RUN_JOBS=1
# RUN_INLINE_QUEUE=1
