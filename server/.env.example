DATABASE_URL=postgresql://user:password@localhost:5432/profai?schema=public
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRATION=7d
PORT=5000
CORS_ORIGIN=http://localhost:3000
UPLOAD_MAX_SIZE=10485760

# Gemini API (Google AI Studio: https://aistudio.google.com/app/apikey)
# Runs on the AI Studio *free tier* by default; leave GEMINI_FREE_TIER=true
# unless you have upgraded to paid (Google Cloud) billing. The flag only
# affects how AICallLog rows are tagged for cost reporting.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FREE_TIER=true

# Background jobs (Phase 5+). BullMQ + Redis power the spaced-repetition
# scheduler and study-group maintenance. Leave RUN_JOBS unset on web-only
# processes (the worker tier should set it to 1). Tests use
# RUN_INLINE_QUEUE=1 to execute handlers synchronously without Redis.
REDIS_URL=redis://localhost:6379
# RUN_JOBS=1
# RUN_INLINE_QUEUE=1

# Web push — Phase 6 task 6.14. Generate a key pair with:
#   npx web-push generate-vapid-keys
# VAPID_SUBJECT is either a mailto:… URL or a https://… URL that browsers
# use to contact the push-service operator.
# VAPID_PUBLIC_KEY=BJ...
# VAPID_PRIVATE_KEY=...
# VAPID_SUBJECT=mailto:ops@profai.local

# File storage (Phase 7 task 7.2). Set R2_BUCKET to switch to Cloudflare
# R2 (S3-compatible, egress-free). Leaving R2_* unset keeps the existing
# local-disk behaviour (`server/uploads`) — fine for dev and small
# single-node deploys. R2_PUBLIC_BASE_URL is optional; without it the
# provider returns time-limited signed URLs (TTL via R2_SIGNED_URL_TTL_SEC,
# default 3600s).
# R2_ACCOUNT_ID=...
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_BUCKET=profai-uploads
# R2_PUBLIC_BASE_URL=https://cdn.profai.io
# R2_SIGNED_URL_TTL_SEC=3600
# LOCAL_UPLOADS_DIR=uploads

# Multi-provider AI (Phase 6 task 6.3). Gemini is primary; Claude is the
# fallback for text-only features (style summary, study pack narration,
# post-exam reconstruct). Leave CLAUDE_API_KEY blank to disable fallback —
# callers degrade gracefully. OpenAI Realtime slot is reserved for the
# voice tutor (Phase 6 6.11) when Gemini Live is geo-restricted.
# CLAUDE_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-opus-4-7
# OPENAI_API_KEY=sk-...
# OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
