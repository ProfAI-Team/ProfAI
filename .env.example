# ===========================================
# ProfAI Environment Variables
# ===========================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# Database
DATABASE_URL=postgresql://profai:profai123@localhost:5432/profai?schema=public
POSTGRES_USER=profai
POSTGRES_PASSWORD=profai123
POSTGRES_DB=profai

# Server
PORT=5000
NODE_ENV=development

# Authentication
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRATION=24h

# CORS
CORS_ORIGIN=http://localhost:3000

# File Upload
UPLOAD_MAX_SIZE=10485760

# Gemini API (Google AI Studio: https://aistudio.google.com/app/apikey)
# ProfAI ships on the AI Studio *free tier* — 15 req/min and 1500 req/day
# for gemini-2.5-flash-lite are more than enough for Phase 0-3 scale.
# Paid (Google Cloud) billing is opt-in: set GEMINI_FREE_TIER=false if you
# upgrade the project so the AICallLog.costUsd totals reflect real spend.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_FREE_TIER=true
